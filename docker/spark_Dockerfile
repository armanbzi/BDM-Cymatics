FROM apache/spark:3.5.2-scala2.12-java11-python3-ubuntu

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ffmpeg \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Hadoop S3A jars for History Server / MinIO event logs
ARG HADOOP_AWS_VERSION=3.3.4
ARG AWS_SDK_VERSION=1.12.367
RUN set -eux; \
    cd /opt/spark/jars; \
    curl -fsSLO "https://repo1.maven.org/maven2/org/apache/hadoop/hadoop-aws/${HADOOP_AWS_VERSION}/hadoop-aws-${HADOOP_AWS_VERSION}.jar"; \
    curl -fsSLO "https://repo1.maven.org/maven2/com/amazonaws/aws-java-sdk-bundle/${AWS_SDK_VERSION}/aws-java-sdk-bundle-${AWS_SDK_VERSION}.jar"; \
    chown spark:spark hadoop-aws-*.jar aws-java-sdk-bundle-*.jar

# Python deps for PySpark jobs
RUN pip install --no-cache-dir \
    numpy scipy pandas pyarrow pyspark opencv-python minio requests python-dotenv

# Use Java from the base image (/opt/java/openjdk) — do not override JAVA_HOME

USER spark
