# MinIO configuration for landing_zone
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=<user-name>
MINIO_SECRET_KEY=<password>
MINIO_SECURE=false
MINIO_BUCKET=landing-zone


# FreeSound API (https://freesound.org/home/app_permissions/)
FREESOUND_CLIENT_ID=<key>
FREESOUND_API_KEY=<key>
# Optional: Freesound can be slow — tune if you see read timeouts (seconds / count)
# FREESOUND_CONNECT_TIMEOUT=20
# FREESOUND_READ_TIMEOUT=120
# FREESOUND_DOWNLOAD_TIMEOUT=300
# FREESOUND_MAX_RETRIES=5

# Kafka (warm-path and hot-path, same MinIO)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_WARM=landing-zone-events-warm-path
KAFKA_TOPIC_HOT=landing-zone-events-hot-path

# ESC-50 dataset (https://github.com/karolpiczak/ESC-50)
ESC50_BASE_PATH=/path/to/ESC-50

# Airflow Web UI (docker-compose airflow-init creates this user)
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# SonarQube — PostgreSQL (docker-compose sonar-postgres + SonarQube JDBC; must match)
SONAR_JDBC_USERNAME=sonar
SONAR_JDBC_PASSWORD=sonar

# SonarQube — web UI / scanner (orchestrate option 7). Token preferred; else username+password.
# Generate token: http://localhost:9090/account/security
SONAR_TOKEN=
SONAR_USERNAME=admin
SONAR_PASSWORD=admin

