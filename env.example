# Copy to .env and fill in values. Used by host scripts, orchestrate.py, and docker compose.

# --- MinIO (all zones) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=<user-name>
MINIO_SECRET_KEY=<password>
MINIO_SECURE=false
LANDING_ZONE_BUCKET=landing-zone
TRUSTED_ZONE_BUCKET=trusted-zone
EXPLOITATION_ZONE_BUCKET=exploitation-zone

# --- Landing: cold path (Freesound) ---
FREESOUND_API_KEY=<key>
# Optional timeouts (seconds) / retries:
# FREESOUND_CONNECT_TIMEOUT=20
# FREESOUND_READ_TIMEOUT=120
# FREESOUND_DOWNLOAD_TIMEOUT=300
# FREESOUND_MAX_RETRIES=5

# --- Landing: cold path (ESC-50) ---
# optional if is already available locally,
# ESC50_BASE_PATH=/path/to/ESC-50

# --- Landing: hot path ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_HOT=landing-zone-events-hot-path
KAFKA_EVENTS_HOT_PREFIX=metadata/kafka-events/hot-path


# --- Spark batch (docker compose trusted-spark-batch / exploitation-spark-batch) ---
SPARK_EVENT_LOG_ENABLED=true
SPARK_EVENT_LOG_PREFIX=spark-logs/
SPARK_DRIVER_MEMORY=2g
SPARK_SQL_SHUFFLE_PARTITIONS=8
SPARK_LOG_LEVEL=WARN

# --- Airflow (docker compose) ---
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow
AIRFLOW_POSTGRES_DB=airflow

# --- SonarQube (orchestrate option 8; docker compose sonar-postgres) ---
SONAR_JDBC_USERNAME=sonar
SONAR_JDBC_PASSWORD=sonar
SONAR_TOKEN=
SONAR_USERNAME=admin
SONAR_PASSWORD=admin

# Jupyter Spark on host only — set in the notebook kernel, not in root .env:
# SPARK_ALLOW_HOST_DRIVER=1
# SPARK_MASTER=spark://localhost:7077
# SPARK_S3A_ENDPOINT=http://127.0.0.1:9000
# SPARK_DRIVER_HOST=host.docker.internal
